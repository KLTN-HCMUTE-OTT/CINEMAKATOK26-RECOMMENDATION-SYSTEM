POSTGRES_URL_AUDIT=
POSTGRES_URL_CONTENT=

# PostgreSQL Database Configuration (alternative to POSTGRES_URL)
# Use individual params if POSTGRES_URL is not set
AUDIT_DB_HOST=localhost
AUDIT_DB_USER=postgres
AUDIT_DB_PASSWORD=your_password
AUDIT_DB_NAME=recommendation_db
AUDIT_DB_PORT=5432

CONTENT_DB_HOST=localhost
CONTENT_DB_USER=postgres
CONTENT_DB_PASSWORD=your_password
CONTENT_DB_NAME=recommendation_db
CONTENT_DB_PORT=5432

# Cron Security Secret
CRON_SECRET=your_secret_key_here
